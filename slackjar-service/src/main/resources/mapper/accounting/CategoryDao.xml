<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slack.slackjarservice.accounting.dao.CategoryDao">

    <select id="selectByType" resultType="com.slack.slackjarservice.accounting.entity.Category">
        SELECT * FROM category
        WHERE type = #{type}
          AND is_active = 1
          AND deleted = 0
        ORDER BY sort_order ASC
    </select>

</mapper>