<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slack.slackjarservice.accounting.dao.CategoryDao">

    <resultMap type="com.slack.slackjarservice.accounting.entity.Category" id="CategoryMap">
        <result property="id" column="id" jdbcType="BIGINT"/>
        <result property="name" column="name" jdbcType="VARCHAR"/>
        <result property="type" column="type" jdbcType="VARCHAR"/>
        <result property="icon" column="icon" jdbcType="VARCHAR"/>
        <result property="color" column="color" jdbcType="VARCHAR"/>
        <result property="parentId" column="parent_id" jdbcType="BIGINT"/>
        <result property="sortOrder" column="sort_order" jdbcType="INTEGER"/>
        <result property="isSystem" column="is_system" jdbcType="TINYINT"/>
        <result property="isActive" column="is_active" jdbcType="TINYINT"/>
        <result property="remark" column="remark" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="BIGINT"/>
        <result property="updateTime" column="update_time" jdbcType="BIGINT"/>
        <result property="deleted" column="deleted" jdbcType="TINYINT"/>
        <result property="version" column="version" jdbcType="BIGINT"/>
    </resultMap>

    <select id="selectByType" resultMap="CategoryMap">
        SELECT id, name, type, icon, color, parent_id, sort_order, is_system, is_active, remark, create_time, update_time, deleted, version
        FROM category
        WHERE deleted = 0 AND type = #{type}
        ORDER BY sort_order ASC
    </select>

</mapper>
